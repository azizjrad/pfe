# Laravel application environment example
APP_NAME=Elite Drive
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Frontend URL used for email links (change for your dev/frontend host)
FRONTEND_URL=http://localhost:5173

# Database (fill as needed)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Mail
# Default for local development: log mails to the application log (safe, no external provider required)
MAIL_MAILER=log

# SMTP example (uncomment and set these when you configure a real mail provider like SendGrid)
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your_sendgrid_api_key_or_smtp_password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=no-reply@yourdomain.com
# MAIL_FROM_NAME="Elite Drive"

# Alternatively, when using SendGrid API:
# SENDGRID_API_KEY=

# Queue driver
# Default local setting uses `sync` so jobs run inline. Use `database`/`redis` in production and run queue workers.
QUEUE_CONNECTION=sync

# Other environment variables...
