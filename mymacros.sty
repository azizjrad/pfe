%Big right arrows
\catcode`\@=11
\def\rightarrowfill{$\m@th \mathord- \mkern-6mu
  \cleaders\hbox{$\mkern-2mu \mathord- \mkern-2mu$}\hfill
  \mkern-6mu \mathord\rightarrow$}
\catcode`\@=12
%use:    \hbox to 5cm{\rightarrowfill}
\def\mapup#1{\Big\uparrow
  \rlap{$\vcenter{\hbox{$\scriptstyle #1$}}$}}
\def\mapright#1#2{\smash{
  \mathop{\hbox to #1{\rightarrowfill}}\limits^{#2}}}
  
  
