\font\thebig=cmss17 scaled 3500

\def\@makechapterhead#1{ \vspace*{2pt} { \parindent 0pt
  \begin{flushright}\thebig\thechapter\vspace*{-8pt}\\
     \fontfamily{cmss}\fontseries{bx}\Huge #1
  \end{flushright}
\nobreak \vskip 10pt }  }

\def\@makeschapterhead#1{ \vspace*{20pt} { \parindent 0pt
 \begin{flushright}\fontfamily{cmss}\fontseries{bx}\Huge #1
 \end{flushright}
 \nobreak \vskip 20pt } }

