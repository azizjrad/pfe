@baseUrl = http://localhost:8000/api

###########################################
# 1. LOGIN SUPER ADMIN
###########################################

POST {{baseUrl}}/login
Content-Type: application/json

{
    "email": "admin@elitedrive.com",
    "password": "Admin2024!"
}

### Response attendue :
### {
###   "message": "Connexion réussie",
