###########################################
# 2. GET USER INFO (après login)
###########################################

### ⚠️ Remplacer YOUR_TOKEN par le token reçu du login
@token = YOUR_TOKEN_HERE

GET {{baseUrl}}/user
Authorization: Bearer {{token}}


###########################################
# 3. LOGOUT SUPER ADMIN
###########################################

POST {{baseUrl}}/logout
Authorization: Bearer {{token}}
